{
  "$schema": "youtube-template.v1.0",
  "series": "A",
  "name": "옷 입는 웹툰",
  "resolution": "1080x1920",
  "fps": 30,
  "format": "mp4",

  "structure": [
    {
      "scene": "intro",
      "duration": "3s",
      "content": "캐릭터 등장 + 에피소드 타이틀",
      "source": "webtoon panel[0]",
      "transition": "fade_in"
    },
    {
      "scene": "story",
      "duration": "120-240s",
      "content": "4컷 에피소드 전개",
      "source": "webtoon panels[1..3]",
      "transition": "slide_up",
      "bgm": "lyria3/webtoon/"
    },
    {
      "scene": "product_reveal",
      "duration": "30s",
      "content": "자연스러운 착용 클로즈업",
      "source": "main.jpg + detail-*.jpg",
      "transition": "zoom_in"
    },
    {
      "scene": "outro",
      "duration": "15s",
      "content": "구매 링크 + 다음 에피소드 예고",
      "overlay": {
        "coupang_url": true,
        "naver_url": true,
        "showroom_url": true
      },
      "transition": "fade_out"
    }
  ],

  "description_template": "video-spec.json#description_template",
  "thumbnail": {
    "source": "webtoon panel[2] (reflection cut)",
    "text_overlay": "에피소드 번호 + 상품명",
    "size": "1280x720"
  }
}
