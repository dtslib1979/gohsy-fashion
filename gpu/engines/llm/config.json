{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "id": "gohsy-fashion-llm-engine",
  "version": "3.0.0",
  "name": "GOHSY FASHION LLM Engine",
  "description": "패션 커머스 AI 에이전트 엔진",

  "models": {
    "primary": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-20250514",
      "maxTokens": 4096,
      "temperature": 0.7,
      "useCases": ["product_description", "style_recommendation", "content_generation"]
    },
    "local": {
      "provider": "ollama",
      "model": "llama3:8b",
      "endpoint": "http://localhost:11434",
      "useCases": ["draft", "summary", "tag_generation"]
    },
    "embedding": {
      "provider": "openai",
      "model": "text-embedding-3-small",
      "dimensions": 1536
    }
  },

  "agents": {
    "copywriter": {
      "name": "Product Copywriter",
      "description": "상품 설명/카피 생성 에이전트",
      "promptPath": "prompts/copywriter.md",
      "model": "primary",
      "capabilities": ["상품설명", "SNS카피", "상세페이지텍스트", "태그생성"]
    },
    "stylist": {
      "name": "Style Recommender",
      "description": "코디/스타일 추천 에이전트",
      "promptPath": "prompts/stylist.md",
      "model": "primary",
      "capabilities": ["코디추천", "스타일매칭", "체형별추천", "시즌코디"]
    },
    "seo": {
      "name": "SEO Optimizer",
      "description": "쿠팡/네이버 검색 최적화 에이전트",
      "promptPath": "prompts/seo.md",
      "model": "primary",
      "capabilities": ["키워드추출", "제목최적화", "태그추천", "검색어분석"]
    },
    "support": {
      "name": "Customer Support",
      "description": "고객 문의 응대 에이전트",
      "promptPath": "prompts/support.md",
      "model": "primary",
      "capabilities": ["사이즈문의", "배송문의", "교환반품", "상품문의"]
    }
  },

  "chains": {
    "productLaunch": {
      "name": "Product Launch Chain",
      "description": "card.json → 카피 → SEO → 상세페이지 텍스트 생성",
      "steps": [
        { "agent": "copywriter", "output": "copy" },
        { "agent": "seo", "input": "copy", "output": "optimized" },
        { "agent": "stylist", "input": "copy", "output": "styling" }
      ]
    }
  },

  "rateLimit": {
    "requestsPerMinute": 60,
    "tokensPerMinute": 100000,
    "retryAttempts": 3,
    "retryDelay": 1000
  },

  "logging": {
    "enabled": true,
    "path": "analytics/llm-logs/",
    "format": "jsonl",
    "retention": "30d"
  }
}
