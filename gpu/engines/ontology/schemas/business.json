{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "@context": {
    "@vocab": "https://schema.org/",
    "gohsy": "https://gohsy.com/schema/"
  },
  "@type": "gohsy:FashionCommerceSchema",
  "version": "3.0.0",
  "description": "패션 커머스 도메인 온톨로지",

  "entities": {
    "Product": {
      "@type": "gohsy:Product",
      "description": "상품 엔티티 (= PRODUCT_CARD)",
      "properties": {
        "product_id": { "type": "string", "pattern": "^PROD-\\d{3}$" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "season": { "type": "string", "enum": ["SS2026", "FW2026", "ALL"] },
        "price": { "$ref": "#/entities/Price" },
        "spec": { "$ref": "#/entities/Spec" },
        "style_module": { "$ref": "#/entities/StyleModule" },
        "channels": { "$ref": "#/entities/ChannelStatus" },
        "content_matrix": { "$ref": "#/entities/ContentMatrix" }
      },
      "required": ["product_id", "name", "category", "price"]
    },

    "Price": {
      "@type": "gohsy:Price",
      "properties": {
        "cost": { "type": "number" },
        "retail": { "type": "number" },
        "coupang": { "type": "number" },
        "naver": { "type": "number" },
        "currency": { "type": "string", "default": "KRW" }
      }
    },

    "Spec": {
      "@type": "gohsy:Spec",
      "properties": {
        "material": { "type": "string" },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "colors": { "type": "array", "items": { "type": "string" } },
        "weight": { "type": "string" },
        "origin": { "type": "string" },
        "care": { "type": "string" }
      }
    },

    "StyleModule": {
      "@type": "gohsy:StyleModule",
      "description": "Style Master Engine V-F-C-D 모델",
      "properties": {
        "variables": {
          "type": "object",
          "properties": {
            "silhouette_type": { "type": "string", "enum": ["Box", "A", "H", "Y", "O"] },
            "upper_length_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
            "pant_width_category": { "type": "string", "enum": ["Skinny", "Straight", "Wide", "Flare"] },
            "layer_depth": { "type": "integer", "minimum": 1, "maximum": 5 },
            "contrast_index": { "type": "number", "minimum": 0, "maximum": 1 },
            "formality_score": { "type": "number", "minimum": 0, "maximum": 1 },
            "season": { "type": "string" }
          }
        },
        "formula_ids": { "type": "array", "items": { "type": "string" } },
        "context": { "type": "string" },
        "source_archive": { "type": ["string", "null"] }
      }
    },

    "ChannelStatus": {
      "@type": "gohsy:ChannelStatus",
      "properties": {
        "coupang": { "type": "object" },
        "naver": { "type": "object" },
        "youtube": { "type": "object" },
        "showroom": { "type": "object" }
      }
    },

    "ContentMatrix": {
      "@type": "gohsy:ContentMatrix",
      "properties": {
        "real_model": { "type": "object" },
        "webtoon": { "type": "object" },
        "fantasy": { "type": "object" },
        "cad": { "type": "object" }
      }
    }
  },

  "relationships": {
    "belongsTo": { "from": "Product", "to": "Category" },
    "styledBy": { "from": "Product", "to": "StyleModule" },
    "soldOn": { "from": "Product", "to": "ChannelStatus" }
  }
}
